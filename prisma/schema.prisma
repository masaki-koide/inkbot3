generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model NotificationEntry {
  id        Int      @id @default(autoincrement())
  guildId   String
  channelId String
  hour      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, channelId])
}

model CommandLog {
  id          Int      @id @default(autoincrement())
  commandName String
  guildId     String
  guildName   String
  channelId   String
  channelName String
  userId          String
  userName        String
  userDisplayName String
  options     String?
  createdAt   DateTime @default(now())
}
