generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model NotificationEntry {
  id        Int      @id @default(autoincrement())
  guildId   String
  channelId String
  hour      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, channelId])
}
